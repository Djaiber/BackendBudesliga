# AWS Configuration
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=123456789012

# DynamoDB
DYNAMODB_TABLE=connected-arena
DYNAMODB_ENDPOINT=  # Leave empty for AWS, set to http://localhost:4566 for localstack

# API Gateway WebSocket
WEBSOCKET_API_ENDPOINT=wss://your-api-id.execute-api.eu-central-1.amazonaws.com/prod

# EventBridge
EVENT_BUS_NAME=connected-arena-events

# S3
S3_REPLAY_BUCKET=bundesliga-replay-data
S3_ENDPOINT=  # Leave empty for AWS, set to http://localhost:4566 for localstack

# Bedrock AI
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=us-east-1  # Bedrock may be in different region
PROMPT_CACHE_TTL_SECONDS=60

# Cognito (for JWT validation)
COGNITO_USER_POOL_ID=eu-central-1_XXXXXXXXX
COGNITO_REGION=eu-central-1

# Replay Engine
REPLAY_SPEED=60  # 1 match minute = 1 real second (60x speed)
REPLAY_DATA_PATH=scripts/output/events.json  # For local dev

# Game Engine
PREDICTION_WINDOW_DURATION_SECONDS=20
GAME_ENGINE_TICK_INTERVAL_SECONDS=30

# Room Management
MIN_PLAYERS_PER_ROOM=3
MAX_PLAYERS_PER_ROOM=4
MAX_LEADERBOARD_MERGE_SIZE=25
INACTIVE_ROOM_THRESHOLD_SECONDS=300

# Scoring
EXACT_PREDICTION_POINTS=100
CLOSEST_PREDICTION_POINTS=50,30,20,10  # Comma-separated descending
NO_RESPONSE_PENALTY=-10
SPEED_MULTIPLIER_MAX=1.1

# Streaks
STREAK_3_MULTIPLIER=1.2
STREAK_5_MULTIPLIER=1.5

# Tiers (EXP thresholds)
TIER_ENTHUSIAST_MIN=401
TIER_AMATEUR_MIN=701
TIER_SAVVY_MIN=901

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json or text

# Local Development
LOCAL_MODE=false  # Set to true to disable AWS calls
